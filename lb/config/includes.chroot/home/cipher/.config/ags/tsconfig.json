{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "astal/gtk3",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "astal/*": ["node_modules/astal/src/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
