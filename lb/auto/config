#!/bin/bash
# CipherOS XLVII — live-build configuration
#
# Flag choices verified against the live-build manpage (lb_config(1), current
# across Debian testing/unstable/trixie/bookworm) and against a working Kali
# live-build-config reference (github.com/prateepb/kali-live-build). Kali is
# treated as the distribution directly — no --mode/--parent-* indirection,
# matching how Kali's own build scripts do it.
#
# Build host requirement: this must be run on Kali Linux itself, or a Debian
# host with the `kali-archive-keyring` package available, so that
# --keyring-packages can pull a keyring live-build trusts for the Kali
# mirror. Building on a vanilla Ubuntu/Debian host without that keyring
# present will cause apt-secure signature verification to fail during
# bootstrap. See README.md "Build prerequisites".
set -e
lb config noauto \
    --apt-options "--yes -oAcquire::http::Timeout=60 -oAcquire::Retries=3" \
    --archive-areas "main contrib non-free non-free-firmware" \
    -a amd64 \
    --binary-images iso-hybrid \
    --bootappend-live "boot=live components quiet splash username=cipher hostname=cipheros locales=en_GB.UTF-8 keyboard-layouts=gb cipher.ai=enabled cipher.voice=auto" \
    --bootappend-live-failsafe "boot=live components memtest noapic noapm nodma nomce nolapic nomodeset nosmp nosplash vga=normal" \
    --bootloaders "grub-efi,syslinux" \
    --checksums sha256 \
    --chroot-filesystem squashfs \
    --compression xz \
    --debootstrap-options "--include=apt-transport-https,ca-certificates,gnupg" \
    --distribution kali-rolling \
    --keyring-packages kali-archive-keyring \
    --iso-application "CipherOS XLVII Phantom Signal" \
    --iso-preparer "CipherOS Build System" \
    --iso-publisher "CipherOS Project" \
    --iso-volume "CipherOS XLVII" \
    --linux-flavours amd64 \
    --memtest none \
    --mirror-bootstrap "http://http.kali.org/kali" \
    --mirror-binary "http://http.kali.org/kali" \
    --security false \
    --updates false \
    --system live \
    "${@}"
