#!/bin/bash
# CipherOS XLVII — live-build configuration
#
# Build host requirement: Kali Linux or Kali container.

set -e

echo "====================================="
echo "EXECUTING lb/auto/config"
echo "Current directory:"
pwd
echo "====================================="

lb config noauto \
    --apt-options "--yes -oAcquire::http::Timeout=60 -oAcquire::Retries=3" \
    --archive-areas "main contrib non-free non-free-firmware" \
    -a amd64 \
    --binary-images iso-hybrid \
    --bootappend-live "boot=live components quiet splash username=cipher hostname=cipheros locales=en_GB.UTF-8 keyboard-layouts=gb cipher.ai=enabled cipher.voice=auto" \
    --bootappend-live-failsafe "boot=live components memtest noapic noapm nodma nomce nolapic nomodeset nosmp nosplash vga=normal" \
    --bootloaders "grub-efi,syslinux" \
    --checksums sha256 \
    --chroot-filesystem squashfs \
    --compression xz \
    --debootstrap-options "--include=apt-transport-https,ca-certificates,gnupg" \
    --distribution kali-rolling \
    --keyring-packages kali-archive-keyring \
    --iso-application "CipherOS XLVII Phantom Signal" \
    --iso-preparer "CipherOS Build System" \
    --iso-publisher "CipherOS Project" \
    --iso-volume "CipherOS XLVII" \
    --linux-flavours amd64 \
    --memtest none \
    --mirror-bootstrap "https://http.kali.org/kali" \
    --mirror-binary "https://http.kali.org/kali" \
    --security false \
    --updates false \
    --system live \
    "$@"