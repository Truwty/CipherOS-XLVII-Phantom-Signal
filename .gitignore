# live-build working directories and generated artifacts — these are
# multi-GB and regenerated by `sudo bash build.sh` / `lb build`, never
# commit them.
lb/.build/
lb/cache/
lb/chroot/
lb/binary/
lb/*.iso
lb/*.contents
lb/*.files
lb/*.packages
lb/*.zsync
lb/*.build
lb/*.log

# build.sh outputs and logs
output/
logs/
build.log

# Python
__pycache__/
*.pyc
*.pyo

# editor/OS noise
.DS_Store
*.swp
*~
